# ─── Database ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3307          # 3307 when connecting to Docker-mapped MySQL from host; 3306 inside Docker
DB_NAME=parksmartdb
DB_USER=parksmartuser
DB_PASSWORD=your_db_password_here

# ─── App ──────────────────────────────────────────
DEBUG=True
GATEWAY_SECRET=gateway-internal-secret-key

# ─── Service URLs ─────────────────────────────────
PARKING_SERVICE_URL=http://parking-service:8000
BOOKING_SERVICE_URL=http://booking-service:8000
REALTIME_SERVICE_URL=http://realtime-service-go:8006

# ─── Storage ──────────────────────────────────────
MEDIA_ROOT=/app/media
ML_MODELS_DIR=/app/ml/models

# ─── License Plate Model ──────────────────────────
PLATE_MODEL_PATH=/app/app/models/license-plate-finetune-v1m.pt

# ─── YOLO11n Parking Slot Occupancy Detection ─────
# Path to YOLO11n .pt weights file (Docker or local path).
# Startup behavior:
# 1) If this file exists -> load from this configured path.
# 2) If missing -> call YOLO("yolo11n.pt") so Ultralytics auto-downloads/loads.
# 3) Service then tries to sync downloaded weights back to this path for stable next run.
# 4) If all YOLO loading paths fail -> fallback to OpenCV edge/contour detector.
YOLO_PARKING_MODEL_PATH=/app/ml/models/yolo11n.pt
# Minimum IoU overlap between a detected vehicle box and a slot box
# required to mark the slot as occupied.
YOLO_PARKING_IOU_THRESHOLD=0.15
# Minimum YOLO detection confidence to consider a box as a vehicle.
YOLO_PARKING_CONF_THRESHOLD=0.25

# ─── ESP32 Device Auth ─────────────────────────────
# Token for ESP32 device authentication. Leave empty to skip validation (dev mode).
ESP32_DEVICE_TOKEN=

# ─── Camera URLs ──────────────────────────────────
# DroidCam base URL (QR scanning). /video path is appended by the app.
CAMERA_DROIDCAM_URL=http://192.168.100.130:4747
# RTSP stream for plate recognition (EZVIZ camera)
CAMERA_RTSP_URL=rtsp://user:password@192.168.1.100:554/H.264
# HTTP camera fallback
CAMERA_HTTP_URL=http://192.168.100.130:80
