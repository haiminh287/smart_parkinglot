# Auth Service — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.
# All variables marked REQUIRED must be set — there are no insecure defaults.

# Django
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database (REQUIRED — no fallback defaults)
DB_HOST=localhost
DB_PORT=3307
DB_USER=CHANGE_ME_IN_PRODUCTION
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Redis
REDIS_URL=redis://localhost:6379/1

# RabbitMQ (REQUIRED — no fallback defaults)
RABBITMQ_URL=amqp://CHANGE_ME_USER:CHANGE_ME_PASS@localhost:5672/
RABBITMQ_USER=CHANGE_ME_IN_PRODUCTION
RABBITMQ_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Internal gateway auth (REQUIRED — must match gateway-service-go GATEWAY_SECRET)
GATEWAY_SECRET=CHANGE_ME_IN_PRODUCTION

# OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback/
OAUTH_STATE_SECRET=CHANGE_ME_IN_PRODUCTION
OAUTH_STATE_TTL_SECONDS=300

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
