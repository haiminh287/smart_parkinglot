# ParkSmart Backend Environment Variables

# Django
SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database
DB_HOST=mysql
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_URL=amqp://your-rabbitmq-user:your-rabbitmq-pass@rabbitmq:5672/
RABBITMQ_USER=your-rabbitmq-user
RABBITMQ_PASS=your-rabbitmq-pass

# Internal gateway auth (shared across services)
GATEWAY_SECRET=your-gateway-secret

# OAuth2 (Auth Service)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/oauth/google/callback

FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-secret
FACEBOOK_REDIRECT_URI=http://localhost:8001/api/auth/oauth/facebook/callback

# Payment Gateways
MOMO_PARTNER_CODE=your-momo-code
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret

VNPAY_TMN_CODE=your-vnpay-code
VNPAY_HASH_SECRET=your-vnpay-secret

# AI Service
YOLO_MODEL_PATH=/app/models/yolov8_license_plate.pt

# Chatbot service (FastAPI)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Public edge routing (Cloudflare Pages + Tunnel)
PUBLIC_API_BASE_URL=https://api.example.com/api
PUBLIC_WS_BASE_URL=wss://api.example.com/ws
CLOUDFLARE_TUNNEL_HOSTNAME=api.example.com

# Reverse proxy origin settings (tunnel forwards to this internal listener)
REVERSE_PROXY_HOST=localhost
REVERSE_PROXY_PORT=8088
REVERSE_PROXY_PROTOCOL=http

# Forwarded headers policy at origin
TRUST_X_FORWARDED_HEADERS=true
