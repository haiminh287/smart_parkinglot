PORT=8000
ENV=development
DEBUG=true
GATEWAY_SECRET=gateway-internal-secret-key
REDIS_URL=redis://localhost:6379/1

# Internal service URLs
AUTH_SERVICE_URL=http://auth-service:8000
PARKING_SERVICE_URL=http://parking-service:8000
VEHICLE_SERVICE_URL=http://vehicle-service:8000
BOOKING_SERVICE_URL=http://booking-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
REALTIME_SERVICE_URL=http://realtime-service:8000
PAYMENT_SERVICE_URL=http://payment-service:8000
AI_SERVICE_URL=http://ai-service:8000
CHATBOT_SERVICE_URL=http://chatbot-service:8000

# CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend OAuth callback URL
FE_AUTH_CALLBACK_URL=http://localhost:5173/auth/callback

# Gateway session cookie policy
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_MAX_AGE=604800

# Production requirements (when ENV=production):
# - SESSION_COOKIE_DOMAIN is mandatory
# - SESSION_COOKIE_SECURE must be true
# - CORS_ALLOWED_ORIGINS must be https origins only (no localhost)
# - FE_AUTH_CALLBACK_URL must be https
