# spotlove-ai – Production environment
# FE: https://app.ghepdoicaulong.shop
# API: https://api.ghepdoicaulong.shop
# WS:  wss://ws.ghepdoicaulong.shop
#
# ⚠️  VITE_GATEWAY_SECRET phải được inject khi build:
#     - CI: từ GitHub Secret  VITE_GATEWAY_SECRET
#     - Local: set env var trước khi chạy npm run build
#       $env:VITE_GATEWAY_SECRET="your-secret"; npm run build

VITE_API_URL=https://api.ghepdoicaulong.shop
VITE_WS_URL=wss://ws.ghepdoicaulong.shop
VITE_APP_ENV=production
