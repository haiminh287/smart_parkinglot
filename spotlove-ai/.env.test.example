# Playwright E2E test environment variables
# Copy this to .env.test and fill in values
# .env.test is gitignored — DO NOT commit real secrets

# Gateway URL (default: http://localhost:8000)
E2E_GATEWAY_URL=http://localhost:8000

# Gateway secret — must match GATEWAY_SECRET in backend-microservices/.env
E2E_GATEWAY_SECRET=

# Admin credentials for e2e setup
E2E_ADMIN_EMAIL=admin@parksmart.com
E2E_ADMIN_PASSWORD=
